# =============================================================================
# Per-bot secrets. Copy this file to env/<slug>.env (one per bot) and fill in.
# Example:  cp env/example.env env/tg_accounts_01.env
# NEVER commit a filled-in file — real env/*.env are git-ignored.
# =============================================================================

# Bot token from @BotFather  (REQUIRED — the bot will not start without it)
BOT_TOKEN=

# Telegram user IDs allowed into the admin panel, comma-separated.
# Find your id via @userinfobot. Example: ADMIN_IDS=111111111,222222222
ADMIN_IDS=

# Optional: chat/channel/group id that receives order & support notifications.
# Leave empty to send notifications to each admin's private chat instead.
# (For a group, add the bot to it and use the group's negative id.)
ORDERS_CHAT_ID=

# --- Payments ---------------------------------------------------------------
# Card payments via Telegram Payments. Get this token from @BotFather:
#   /mybots -> your bot -> Payments -> pick a provider (Stripe, YooKassa, ...).
# Leave empty to hide the "Картой" button for this bot.
PROVIDER_TOKEN=

# Crypto payments via @CryptoBot -> Crypto Pay -> Create App -> API Token.
# Leave empty to hide the "Криптовалютой" button for this bot.
CRYPTOBOT_TOKEN=

# --- Optional overrides -----------------------------------------------------
# DB_PATH=/app/data/custom.db     # default: /app/data/<slug>.db
# DATA_DIR=/app/data              # where SQLite files live
# LOG_LEVEL=INFO                  # DEBUG for verbose logs
